# Copy to .env (or .env.local) and fill in values. Any variable that
# needs to reach the frontend bundle MUST be prefixed with VITE_.

# Base URL for API requests. Leave blank in local dev — the Vite dev
# server proxies /api/* to http://localhost:8400 (see vite.config.ts).
# In production, set this to the full URL of your reverse proxy, e.g.
# https://journal.home.arpa
VITE_API_URL=

# ---------------------------------------------------------------------
# The variables below are only read by docker-compose.yml (they are
# passed to the journal-server container). They are NOT used by the
# Vite dev server or baked into the frontend bundle.
# ---------------------------------------------------------------------

# REQUIRED for `docker compose up`: server signing key for sessions and
# password-reset tokens. The compose file fails fast if it is unset.
# Generate one with:
#     python -c "import secrets; print(secrets.token_urlsafe(32))"
JOURNAL_SECRET_KEY=

# Provider API keys for the journal-server container. Required for a
# working stack (OCR, transcription, embeddings, mood scoring, entity
# extraction). See docs/deployment.md.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
