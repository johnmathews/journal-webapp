# Copy to .env (or .env.local) and fill in values. Any variable that
# needs to reach the frontend bundle MUST be prefixed with VITE_.

# Base URL for API requests. Leave blank in local dev — the Vite dev
# server proxies /api/* to http://localhost:8400 (see vite.config.ts).
# In production, set this to the full URL of your reverse proxy, e.g.
# https://journal.home.arpa
VITE_API_URL=

# Bearer token for the journal-server REST and MCP endpoints. This is
# REQUIRED in any environment where journal-server is running with
# JOURNAL_API_TOKEN set — which is always, because the server refuses
# to start without one. See journal-server/docs/security.md.
#
# Dev only: this value is read from .env.local and inlined into the
# bundle by Vite at build time. In PRODUCTION the token is NOT baked
# into the image — it's injected at container startup by
# docker/40-journal-config.sh from the JOURNAL_API_TOKEN env var on
# the host. See docs/deployment.md ("Runtime token injection").
#
# Must match the JOURNAL_API_TOKEN value on the server.
# Generate one with:
#     python -c "import secrets; print(secrets.token_urlsafe(32))"
VITE_JOURNAL_API_TOKEN=
